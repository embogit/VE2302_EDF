ECHO             := @echo

SYSROOT          := ${ROOTDIR}/vitis/build/sdk/sysroots/cortexa72-cortexa53-amd-linux

APP_NAME         := vadd_s
APP_EXE          := ${ROOTDIR}/vitis/build/linux/${APP_NAME}
APP_SRC          := ./src/${APP_NAME}.cpp
APP_SRC_DEP      := ./src/*

GCC              ?= aarch64-linux-gnu-g++

GCC_INCLUDES     := -I${SYSROOT}/usr/include/xrt \
                    -I${SYSROOT}/usr/include \
                    -I${XILINX_VITIS}/include

GCC_C_FLAGS      := -O -Wall -std=c++17 \
                    --sysroot=${SYSROOT}

GCC_L_FLAGS      := -lxrt_core -lxrt_coreutil \
                    -L${SYSROOT}/usr/lib \
                    --sysroot=${SYSROOT}

.PHONY: clean help all

help::
	$(ECHO) "Makefile Usage:"
	$(ECHO) "  make all"
	$(ECHO) "      Command to generate the vadd_cpp ps_app used in this design"

all: $(APP_EXE)

$(APP_EXE): $(APP_SRC_DEP) ${SYSROOT}
	${GCC} ${GCC_C_FLAGS} $(APP_SRC) ${GCC_INCLUDES} $(GCC_L_FLAGS) -o $(APP_EXE)

