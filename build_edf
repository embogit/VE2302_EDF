#!/bin/bash
main () {

ROOTDIR=$PWD

#For generate machine conf
SDT_LOCATION=/storage/avnet/petalinux-ve2302-oob/vivado-hw/sdt

#Set if you have cache
SSTATE_CACHE=/storage/sstate-cache
SOURCE_MIRROR=/storage/downloads


repo init -u https://github.com/Xilinx/yocto-manifests.git -b rel-v2025.2 -m default-edf.xml

#Patch for Cisco Umbrella
patch -p1 --ignore-whitespace << 'EOF'
--- a/.repo/repo/project.py
+++ b/.repo/repo/project.py
@@ -3039,6 +3039,7 @@ class Project:
             tmpPath,
             "--netrc-optional",
             "--location",
+            "--insecure",
         ]
         if quiet:
             cmd += ["--silent", "--show-error"]
EOF

repo sync

source edf-init-build-env

cd $ROOTDIR

sources/meta-xilinx/gen-machine-conf/gen-machine-conf parse-sdt --hw-description $SDT_LOCATION -c build/conf -l build/conf/local.conf --machine-name versal-generic-xcve2302

extract_meta
tar zxf meta-user.tar.gz
rm meta-user.tar.gz

cd build

bitbake-layers add-layer ../sources/meta-user


if [ "$SSTATE_CACHE" != "" ]; then
echo "SSTATE_DIR ?= \"$SSTATE_CACHE\"" >> conf/local.conf
fi
if [[ "$SOURCE_MIRROR" != "" ]]; then
echo "SOURCE_MIRROR_URL ?= \"$SOURCE_MIRROR\"" >> conf/local.conf
fi

#Enable usage of generic EDF linux image for Versal by specifying it from commandline
sed -i '/MACHINE = \"versal-generic-xcve2302\"/d' conf/local.conf

MACHINE=versal-generic-xcve2302 bitbake xilinx-bootbin
MACHINE=amd-cortexa72-common bitbake edf-linux-disk-image

wic cp tmp/deploy/images/versal-generic-xcve2302/boot.bin tmp/deploy/images/amd-cortexa72-common/edf-linux-disk-image-amd-cortexa72-common.rootfs.wic:1

echo "WIC image ready, copy it to sd-card with command:"
echo "sudo dd if=tmp/deploy/images/amd-cortexa72-common/edf-linux-disk-image-amd-cortexa72-common.rootfs.wic of=/dev/<your sd card> bs=1M status=progress oflag=sync"

exit 0


}


extract_meta ()
{
lock_dir=_sh185539
MD5SUM=${MD5SUM-md5sum}
f=`${MD5SUM} --version | egrep '^md5sum .*(core|text)utils'`
test -n "${f}" && md5check=true || md5check=false
${md5check} || \
  echo 'Note: not verifying md5sums.  Consider installing GNU coreutils.'
if test "X$1" = "X-c"
then keep_file=''
else keep_file=true
fi
echo=echo
save_IFS="${IFS}"
IFS="${IFS}:"
gettext_dir=
locale_dir=
set_echo=false

for dir in $PATH
do
  if test -f $dir/gettext \
     && ($dir/gettext --version >/dev/null 2>&1)
  then
    case `$dir/gettext --version 2>&1 | sed 1q` in
      *GNU*) gettext_dir=$dir
      set_echo=true
      break ;;
    esac
  fi
done

if ${set_echo}
then
  set_echo=false
  for dir in $PATH
  do
    if test -f $dir/shar \
       && ($dir/shar --print-text-domain-dir >/dev/null 2>&1)
    then
      locale_dir=`$dir/shar --print-text-domain-dir`
      set_echo=true
      break
    fi
  done

  if ${set_echo}
  then
    TEXTDOMAINDIR=$locale_dir
    export TEXTDOMAINDIR
    TEXTDOMAIN=sharutils
    export TEXTDOMAIN
    echo="$gettext_dir/gettext -s"
  fi
fi
IFS="$save_IFS"
if (echo "testing\c"; echo 1,2,3) | grep c >/dev/null
then if (echo -n test; echo 1,2,3) | grep n >/dev/null
     then shar_n= shar_c='
'
     else shar_n=-n shar_c= ; fi
else shar_n= shar_c='\c' ; fi
f=shar-touch.$$
st1=200112312359.59
st2=123123592001.59
st2tr=123123592001.5 # old SysV 14-char limit
st3=1231235901

if   touch -am -t ${st1} ${f} >/dev/null 2>&1 && \
     test ! -f ${st1} && test -f ${f}; then
  shar_touch='touch -am -t $1$2$3$4$5$6.$7 "$8"'

elif touch -am ${st2} ${f} >/dev/null 2>&1 && \
     test ! -f ${st2} && test ! -f ${st2tr} && test -f ${f}; then
  shar_touch='touch -am $3$4$5$6$1$2.$7 "$8"'

elif touch -am ${st3} ${f} >/dev/null 2>&1 && \
     test ! -f ${st3} && test -f ${f}; then
  shar_touch='touch -am $3$4$5$6$2 "$8"'

else
  shar_touch=:
  echo
  ${echo} 'WARNING: not restoring timestamps.  Consider getting and
installing GNU '\''touch'\'', distributed in GNU coreutils...'
  echo
fi
rm -f ${st1} ${st2} ${st2tr} ${st3} ${f}
#
if test ! -d ${lock_dir} ; then :
else ${echo} "lock directory ${lock_dir} exists"
     exit 1
fi
if mkdir ${lock_dir}
then ${echo} "x - created lock directory ${lock_dir}."
else ${echo} "x - failed to create lock directory ${lock_dir}."
     exit 1
fi
# ============= meta-user.tar.gz ==============
if test -n "${keep_file}" && test -f 'meta-user.tar.gz'
then
${echo} "x - SKIPPING meta-user.tar.gz (file already exists)"

else
${echo} "x - extracting meta-user.tar.gz (text)"
  sed 's/^X//' << 'SHAR_EOF' | uudecode &&
