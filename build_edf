#!/bin/bash
####################################################################
#User settings
####################################################################
#Set if you have sstate cache, can be overriden from commandline
SSTATE_CACHE=/storage/sstate-cache
SOURCE_MIRROR=/storage/downloads
####################################################################

#Internal globals
INSECURE_MODE=0
PLATFORM=0
VIVADO=2025.2

main ()
{
    #Parse commandline
    parse_cmd "$@"


    ROOTDIR=$PWD

    #For generate machine conf
    SDT_LOCATION=vivado-hw/sdt

    #Get vivado version
    LOPPER=$(which lopper)
    if [[ $LOPPER == *"2025.2"* ]]; then
        VIVADO="2025.2"
    elif [[ $LOPPER == *"2026.1"* ]]; then
        VIVADO="2026.1"
    else
        echo "Unknown Vivado version (lopper not found from Vivado path)"
        exit 1
    fi

    repo init -u https://github.com/Xilinx/yocto-manifests.git -b rel-v$VIVADO -m default-edf.xml

    #Select correct HW platform, for 2026.1 always platform as it is superset
    if [[ $VIVADO == "2025.2" ]]; then
        if [[ $PLATFORM == 0 ]]; then
            HW_PROJECT=ve2302_oob_2025_2
        else
            HW_PROJECT=ve2302_platform_2025_2
        fi
    elif [[ $VIVADO == "2026.1" ]]; then
            HW_PROJECT=ve2302_platform_2026_1
    else
        echo "Unsupported Vivado version $VIVADO"
        exit 1
    fi

    #Insecure mode patching
    patch_insecure

    repo sync


    #Needed early for build-machine-conf
    set $ROOTDIR/build  #This is mandatory fue to shift + next script interactions
    source edf-init-build-env

    cd $ROOTDIR

    #Build HW if it does not exist
    if [ ! -d $SDT_LOCATION ]; then
        make -f Makefile DESIGN_NAME=$HW_PROJECT -C vivado-hw
        make -f Makefile DESIGN_NAME=$HW_PROJECT vitis_xsa_export -C vivado-hw
        
        #Check that we have SDT i.e. build did not fail
        if [ ! -d $SDT_LOCATION ]; then
            echo "Vivado SDT articats do not exist, possibly failed build"
            exit 1
        fi
    else
        echo "Vivado build exists, if you want to rebuild use -clean_hw option first"
    fi

    sources/meta-xilinx/gen-machine-conf/gen-machine-conf parse-sdt --template ve2302.yaml --hw-description $SDT_LOCATION -c build/conf -l build/conf/local.conf --machine-name versal-generic-xcve2302 --multiconfigfull
    
    #Add local packages to build keeping compatibility with petalinux also
    if ! grep -q peekpoke "build/conf/local.conf"; then
        grep CON sources/meta-user/conf/user-rootfsconfig | sed 'sxCONFIG_\(.*\)xIMAGE_INSTALL:append = " \1"x' >> build/conf/local.conf

        #Add few editors
        echo "IMAGE_INSTALL:append = \" nano\""  >> build/conf/local.conf
        echo "IMAGE_INSTALL:append = \" emacs\"" >> build/conf/local.conf
        
        #Add packets needed for AIE/HLS
        echo "IMAGE_INSTALL:append = \" xrt\""  >> build/conf/local.conf
        echo "IMAGE_INSTALL:append = \" xrt-dev\""  >> build/conf/local.conf
        echo "IMAGE_INSTALL:append = \" libsysfs\""  >> build/conf/local.conf
	echo "IMAGE_INSTALL:append = \" ai-engine-driver\""  >> build/conf/local.conf
	echo "IMAGE_INSTALL:append = \" ai-engine-driver-dev\""  >> build/conf/local.conf
	echo "IMAGE_INSTALL:append = \" sysfsutils-dev\""  >> build/conf/local.conf
        
        #Remove warning on unsupported machine
        echo "AMD-EDF_IMAGE_SUPPORTED_MACHINES:append = \" versal-generic-xcve2302\"" >> build/conf/local.conf

        #Add ext4 rootimage for v++ packager
        echo "IMAGE_FSTYPES:append = \" ext4\""  >> build/conf/local.conf
    fi

    cd build

    bitbake-layers add-layer ../sources/meta-user

    #Configure caches to speed up build
    if [ "$SSTATE_CACHE" != "" ]; then
        echo "SSTATE_DIR ?= \"$SSTATE_CACHE\"" >> conf/local.conf
    fi
    if [[ "$SOURCE_MIRROR" != "" ]]; then
        echo "SOURCE_MIRROR_URL ?= \"$SOURCE_MIRROR\"" >> conf/local.conf
    fi

    #Enable usage of generic EDF linux image for Versal by specifying it from commandline separately
    sed -i '/MACHINE = \"versal-generic-xcve2302\"/d' conf/local.conf
    
    #Create boot parts of image (single stage boot)
    MACHINE=versal-generic-xcve2302 bitbake xilinx-bootbin

    #Create Linux userspace
    if [[ $PLATFORM == 0 ]]; then
        MACHINE=versal-generic-xcve2302 bitbake edf-linux-disk-image
        MACHINE=amd-cortexa72-common bitbake meta-edf-app-sdk
        wic cp tmp/deploy/images/versal-generic-xcve2302/boot.bin tmp/deploy/images/versal-generic-xcve2302/edf-linux-disk-image-versal-generic-xcve2302.rootfs.wic:1
        echo "WIC image ready, copy it to sd-card with command:"
        echo "sudo dd if=tmp/deploy/images/amd-cortexa72-common/edf-linux-disk-image-versal-generic-xcve2302.rootfs.wic of=/dev/<your sd card> bs=1M status=progress oflag=sync"
    else
 
        MACHINE=versal-generic-xcve2302 bitbake edf-platform-disk-image
        MACHINE=amd-cortexa72-common bitbake meta-edf-app-sdk
        wic cp tmp/deploy/images/versal-generic-xcve2302/boot.bin tmp/deploy/images/versal-generic-xcve2302/edf-platform-disk-image-versal-generic-xcve2302.rootfs.wic:1
        wic cp tmp/deploy/images/versal-generic-xcve2302/boot.bin tmp/deploy/images/versal-generic-xcve2302/edf-platform-disk-image-versal-generic-xcve2302.rootfs.wic.qemu-sd:1
        
        echo "WIC image ready, copy it to sd-card with command:"
        echo "sudo dd if=tmp/deploy/images/versal-generic-xcve2302/edf-platform-disk-image-versal-generic-xcve2302.rootfs.wic of=/dev/<your sd card> bs=1M status=progress oflag=sync"
    fi


    exit 0

}

parse_cmd ()
{
    __usage="
Usage: $(basename $0) [OPTIONS]

Options:
  -insecure              Insecure download mode not checking certificates
  -platform              Build full platform imagage and SDK
  -sstate <value>        Override SSTATE_CACHE location
  -mirror <value>        Override SOURCE_MIRROR location
  -clean                 Cleans HW + SW build results
  -clean_hw              Cleans HW build
  -clean_sw              Cleans SW build
  -h, --help             Help text

Example:
$(basename $0) -platform -sstate /storage/sstate

"
    while [[ $# -gt 0 ]]; do
        case $1 in
            -insecure)
                INSECURE_MODE=1
                shift
                ;;
            -platform)
                PLATFORM=1
                shift
                ;;
            -sstate)
                SSTATE_CACHE=$2
                shift
                shift
                ;;
            -mirror)
                SOURCE_MIRROR=$2
                shift
                shift
                ;;
            -clean)
                echo "Cleaning HW build results"
                cd vivado-hw
                make -f Makefile clean
                cd ..
                clean_sw
                exit 0
                ;;
            -clean_hw)
                echo "Cleaning HW build results"
                cd vivado-hw
                make -f Makefile clean
                exit 0
                ;;
            -clean_sw)
                clean_sw
                exit 0
                ;;
            -h|--help)
                echo "$__usage"
                shift
                exit 0
                ;;
            -*|--*)
                echo "Unknown option $1"
                exit 1
                ;;
            *)
                shift
                ;;
        esac
    done

}

patch_insecure()
{
    if [[ $INSECURE_MODE == 1 ]]; then 
        echo "Insecure mode, no certificate checking"
        if ! grep -q insecure ".repo/repo/project.py"; then

            #Patch to remove SSL certificate checking
            patch -p1 --ignore-whitespace << 'EOF'
--- a/.repo/repo/project.py
+++ b/.repo/repo/project.py
@@ -3039,6 +3039,7 @@ class Project:
             tmpPath,
             "--netrc-optional",
             "--location",
+            "--insecure",
         ]
         if quiet:
             cmd += ["--silent", "--show-error"]
EOF

        fi
    fi
}

clean_sw ()
{
    echo "Cleaning SW build"
    rm -rf build output

    echo "Cleaning cloned repo"
    rm -rf .repo
    rm -rf sources/meta-amd-adaptive-socs
    rm -rf sources/meta-jupyter
    rm -rf sources/meta-openembedded
    rm -rf sources/meta-xilinx-tsn
    rm -rf sources/meta-amd-edf
    rm -rf sources/meta-kria
    rm -rf sources/meta-qt5
    rm -rf sources/meta-virtualization
    rm -rf sources/meta-zephyr
    rm -rf sources/meta-arm
    rm -rf sources/meta-mingw
    rm -rf sources/meta-ros
    rm -rf sources/meta-vitis
    rm -rf sources/poky
    rm -rf sources/meta-embedded-plus
    rm -rf sources/meta-openamp
    rm -rf sources/meta-security
    rm -rf sources/meta-xilinx
    rm -rf sources/meta-system-controller
    rm -rf sources/meta-rauc
}


#Trick as bash does not have forward declarations
main "$@"
